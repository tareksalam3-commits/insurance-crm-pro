rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── helpers ──────────────────────────────────────────────────────────────

    function isAuth() {
      return request.auth != null;
    }

    function userRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function userCompany() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.companyId;
    }

    function isSuperAdmin() {
      return isAuth() && userRole() == 'super_admin';
    }

    function isSalesManager() {
      return isAuth() && userRole() == 'sales_manager';
    }

    function isManager() {
      return isAuth() && (
        userRole() == 'super_admin' ||
        userRole() == 'sales_manager' ||
        userRole() == 'general_supervisor' ||
        userRole() == 'supervisor'
      );
    }

    function sameCompany(companyId) {
      return userCompany() == companyId;
    }

    // ── companies ─────────────────────────────────────────────────────────────

    match /companies/{companyId} {
      allow read: if isAuth();
      allow write: if isSuperAdmin();
    }

    // ── users ─────────────────────────────────────────────────────────────────

    match /users/{uid} {
      allow read: if isAuth() && (
        request.auth.uid == uid ||
        isSuperAdmin() ||
        (isManager() && sameCompany(resource.data.companyId))
      );
      allow update, delete: if isAuth() && (
        request.auth.uid == uid ||
        isSuperAdmin() ||
        (isSalesManager() && sameCompany(resource.data.companyId))
      );
      // السماح بإنشاء مستخدمين جدد من خلال التطبيق الثانوي عند الموافقة على الطلب
      allow create: if isAuth() && (isSuperAdmin() || isSalesManager());
    }

    // ── registrationRequests ─────────────────────────────────────────────────

    match /registrationRequests/{reqId} {
      allow read: if isAuth() && (
        isSuperAdmin() ||
        (isSalesManager() && sameCompany(resource.data.companyId))
      );
      allow create: if true; // Public — anyone can submit a join request
      allow update, delete: if isAuth() && (
        isSuperAdmin() ||
        (isSalesManager() && sameCompany(resource.data.companyId))
      );
    }

    // ── agents ───────────────────────────────────────────────────────────────

    match /agents/{agentId} {
      allow read: if isAuth() && (
        isSuperAdmin() || sameCompany(resource.data.companyId)
      );
      // create: استخدام request.resource.data (البيانات الجديدة) وليس resource.data
      allow create: if isAuth() && (
        isSuperAdmin() ||
        (isManager() && sameCompany(request.resource.data.companyId))
      );
      allow update, delete: if isAuth() && (
        isSuperAdmin() ||
        (isManager() && sameCompany(resource.data.companyId))
      );
    }

    // ── clients ───────────────────────────────────────────────────────────────

    match /clients/{clientId} {
      allow read: if isAuth() && (
        isSuperAdmin() || sameCompany(resource.data.companyId)
      );
      // create: استخدام request.resource.data (البيانات الجديدة) وليس resource.data
      allow create: if isAuth() && (
        isSuperAdmin() ||
        sameCompany(request.resource.data.companyId)
      );
      allow update, delete: if isAuth() && (
        isSuperAdmin() ||
        sameCompany(resource.data.companyId)
      );
    }

    // ── paymentRecords ────────────────────────────────────────────────────────

    match /paymentRecords/{recordId} {
      allow read: if isAuth() && (
        isSuperAdmin() || sameCompany(resource.data.companyId)
      );
      allow create: if isAuth() && sameCompany(request.resource.data.companyId);
      allow delete: if isAuth() && (
        isSuperAdmin() || isManager() || sameCompany(resource.data.companyId)
      );
    }

    // ── notifications ─────────────────────────────────────────────────────────

    match /notifications/{notifId} {
      allow read: if isAuth() && (
        request.auth.uid == resource.data.recipientId ||
        isSuperAdmin()
      );
      allow create: if isAuth();
      allow update: if isAuth() && request.auth.uid == resource.data.recipientId;
      allow delete: if isAuth() && (
        request.auth.uid == resource.data.recipientId || isSuperAdmin()
      );
    }
  }
}
