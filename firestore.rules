rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── helpers ──────────────────────────────────────────────────────────────

    function isAuth() {
      return request.auth != null;
    }

    function userRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function userCompany() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.companyId;
    }

    function isSuperAdmin() {
      return isAuth() && userRole() == 'super_admin';
    }

    function isSalesManager() {
      return isAuth() && userRole() == 'sales_manager';
    }

    function isManager() {
      return isAuth() && (
        userRole() == 'super_admin' ||
        userRole() == 'sales_manager' ||
        userRole() == 'general_supervisor' ||
        userRole() == 'supervisor'
      );
    }

    function sameCompany(companyId) {
      return userCompany() == companyId;
    }

    // ── companies ─────────────────────────────────────────────────────────────

    match /companies/{companyId} {
      // القراءة مسموحة للجميع — لازم لصفحة طلب الانضمام (المستخدم مش مسجّل)
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    // ── users ─────────────────────────────────────────────────────────────────

    match /users/{uid} {
      allow list: if isAuth();
      allow get: if isAuth();
      allow write: if isAuth() && (
        request.auth.uid == uid ||
        isSuperAdmin() ||
        (isSalesManager() && sameCompany(request.resource.data.companyId))
      );
      allow create: if isAuth() && (
        request.auth.uid == uid ||
        isSuperAdmin() ||
        isManager()
      );
    }

    // ── registrationRequests ─────────────────────────────────────────────────

    match /registrationRequests/{reqId} {
      // list: أي مستخدم مسجّل — الفلترة تتم في الكود
      allow list: if isAuth();
      // get: مسجّل دخول أو سوبر أدمن — بدون تقييد إضافي على مستوى doc
      allow get: if isAuth() || isSuperAdmin();

      // create: غير مسجّل مسموح — لأن الطلب من صفحة تسجيل عامة
      // _pwd مسموح مؤقتاً (يُحذف فور الموافقة)
      allow create: if
        request.resource.data.keys().hasAll(['displayName', 'email', 'companyId', 'requestedRole', 'status']) &&
        request.resource.data.status == 'pending' &&
        request.resource.data.displayName is string &&
        request.resource.data.displayName.size() > 0 &&
        request.resource.data.email is string &&
        request.resource.data.email.size() > 5;

      // update/delete: المراقب العام يقدر يوافق على أي طلب في شركته
      // (managerId فارغ في الطلبات الجديدة — المراقب العام هو من يعيّن)
      allow update, delete: if isAuth() && (
        isSuperAdmin() ||
        (isSalesManager() && sameCompany(resource.data.companyId)) ||
        (
          userRole() == 'general_supervisor' &&
          sameCompany(resource.data.companyId)
        ) ||
        (
          userRole() == 'supervisor' &&
          sameCompany(resource.data.companyId) &&
          resource.data.managerId == request.auth.uid
        )
      );
    }

    // ── agents ───────────────────────────────────────────────────────────────

    match /agents/{agentId} {
      allow list: if isAuth();
      allow get: if isAuth() && (
        isSuperAdmin() || sameCompany(resource.data.companyId)
      );
      // create مسموح للمديرين — يشمل approveRegistrationRequest
      allow create: if isAuth();
      allow update, delete: if isAuth() && (
        isSuperAdmin() ||
        (isManager() && sameCompany(resource.data.companyId))
      );
    }

    // ── clients ───────────────────────────────────────────────────────────────

    match /clients/{clientId} {
      allow list: if isAuth();
      allow get: if isAuth() && (
        isSuperAdmin() || sameCompany(resource.data.companyId)
      );
      // FIX: write مقسّم — الحذف يتطلب manager، الإضافة والتعديل لأي مستخدم بنفس الشركة
      allow create, update: if isAuth() && (
        isSuperAdmin() || sameCompany(request.resource.data.companyId)
      );
      allow delete: if isAuth() && (
        isSuperAdmin() || isManager()
      );
    }

    // ── paymentRecords ────────────────────────────────────────────────────────

    match /paymentRecords/{recordId} {
      allow list: if isAuth();
      allow get: if isAuth() && (
        isSuperAdmin() || sameCompany(resource.data.companyId)
      );
      allow create: if isAuth() && sameCompany(request.resource.data.companyId);
      allow delete: if isAuth() && (
        isSuperAdmin() || isManager()
      );
    }

    // ── notifications ─────────────────────────────────────────────────────────

    match /notifications/{notifId} {
      allow read: if isAuth() && resource.data.recipientId == request.auth.uid;
      allow create: if isAuth();
      allow update: if isAuth() && resource.data.recipientId == request.auth.uid;
      allow delete: if isAuth() && resource.data.recipientId == request.auth.uid;
    }
  }
}
