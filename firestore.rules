rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── helpers ──────────────────────────────────────────────────────────────

    function isAuth() {
      return request.auth != null;
    }

    function userRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function userCompany() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.companyId;
    }

    function isSuperAdmin() {
      return isAuth() && userRole() == 'super_admin';
    }

    function isSalesManager() {
      return isAuth() && userRole() == 'sales_manager';
    }

    function isManager() {
      return isAuth() && (
        userRole() == 'super_admin' ||
        userRole() == 'sales_manager' ||
        userRole() == 'general_supervisor' ||
        userRole() == 'supervisor'
      );
    }

    function sameCompany(companyId) {
      return userCompany() == companyId;
    }

    // ── companies ─────────────────────────────────────────────────────────────

    match /companies/{companyId} {
      // القراءة مسموحة للجميع — لازم لصفحة طلب الانضمام (المستخدم مش مسجّل)
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    // ── users ─────────────────────────────────────────────────────────────────

    match /users/{uid} {
      // list: أي مستخدم مسجّل يقدر يعمل query (مهم لصفحة المستخدمين والتقارير)
      allow list: if isAuth();
      // get: قراءة document واحد — نتحقق من الهوية
      allow get: if isAuth() && (
        request.auth.uid == uid ||
        isSuperAdmin() ||
        (isManager() && sameCompany(resource.data.companyId))
      ) ||
      // قراءة عامة للمديرين — لصفحة طلب الانضمام
      (resource.data.role in ['sales_manager', 'general_supervisor', 'supervisor', 'group_leader']);
      allow write: if isAuth() && (
        request.auth.uid == uid ||
        isSuperAdmin() ||
        (isSalesManager() && sameCompany(resource.data.companyId))
      );
      allow create: if isAuth() && (
        request.auth.uid == uid ||
        isSuperAdmin() ||
        isManager()
      );
    }

    // ── registrationRequests ─────────────────────────────────────────────────

    match /registrationRequests/{reqId} {
      // list: أي مستخدم مسجّل — الفلترة تتم في الكود
      allow list: if isAuth();
      allow get: if isAuth() && (
        isSuperAdmin() ||
        (isSalesManager() && sameCompany(resource.data.companyId)) ||
        (
          (userRole() == 'general_supervisor' || userRole() == 'supervisor') &&
          sameCompany(resource.data.companyId) &&
          resource.data.managerId == request.auth.uid
        )
      );

      // FIX #6: create مقيّد — يجب أن تكون البيانات صحيحة ولا تحوي password
      // لا يُشترط تسجيل دخول لأن الطلب يُرسل من صفحة تسجيل عامة
      allow create: if
        request.resource.data.keys().hasAll(['displayName', 'email', 'companyId', 'requestedRole', 'status']) &&
        request.resource.data.status == 'pending' &&
        request.resource.data.displayName is string &&
        request.resource.data.displayName.size() > 0 &&
        request.resource.data.email is string &&
        request.resource.data.email.size() > 5 &&
        !request.resource.data.keys().hasAny(['password']); // ← منع تخزين كلمة المرور

      allow update, delete: if isAuth() && (
        isSuperAdmin() ||
        (isSalesManager() && sameCompany(resource.data.companyId)) ||
        // المراقب العام والمراقب يقدروا يوافقوا على الطلبات الموجهة إليهم فقط
        (
          isAuth() &&
          (userRole() == 'general_supervisor' || userRole() == 'supervisor') &&
          sameCompany(resource.data.companyId) &&
          resource.data.managerId == request.auth.uid
        )
      );
    }

    // ── agents ───────────────────────────────────────────────────────────────

    match /agents/{agentId} {
      // list query: الكيري بتفلتر بـ companyId == userCompany() فالـ rule تسمح لأي مسجّل
      // get (document واحد): نتحقق إن الـ companyId متطابق
      allow list: if isAuth();
      allow get: if isAuth() && (
        isSuperAdmin() || sameCompany(resource.data.companyId)
      );
      allow create: if isAuth() && (
        isSuperAdmin() ||
        isManager()
      );
      allow update, delete: if isAuth() && (
        isSuperAdmin() ||
        (isManager() && sameCompany(resource.data.companyId))
      );
    }

    // ── clients ───────────────────────────────────────────────────────────────

    match /clients/{clientId} {
      allow list: if isAuth();
      allow get: if isAuth() && (
        isSuperAdmin() || sameCompany(resource.data.companyId)
      );
      // FIX: write مقسّم — الحذف يتطلب manager، الإضافة والتعديل لأي مستخدم بنفس الشركة
      allow create, update: if isAuth() && (
        isSuperAdmin() || sameCompany(request.resource.data.companyId)
      );
      allow delete: if isAuth() && (
        isSuperAdmin() || isManager()
      );
    }

    // ── paymentRecords ────────────────────────────────────────────────────────

    match /paymentRecords/{recordId} {
      allow list: if isAuth();
      allow get: if isAuth() && (
        isSuperAdmin() || sameCompany(resource.data.companyId)
      );
      allow create: if isAuth() && sameCompany(request.resource.data.companyId);
      allow delete: if isAuth() && (
        isSuperAdmin() || isManager()
      );
    }

    // ── notifications ─────────────────────────────────────────────────────────

    match /notifications/{notifId} {
      allow read: if isAuth() && resource.data.recipientId == request.auth.uid;
      allow create: if isAuth();
      allow update: if isAuth() && resource.data.recipientId == request.auth.uid;
      allow delete: if isAuth() && resource.data.recipientId == request.auth.uid;
    }
  }
}
